# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================

# NODE_ENV: 'development' or 'production'
# Controls logging verbosity, error handling, and security strictness
NODE_ENV="development"

# ============================================================================
# DATABASE & AUTHENTICATION
# ============================================================================

# JWT_SECRET: Secret key for JSON Web Token signing
# CRITICAL: In production, set to a strong random 40+ character string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DO NOT use default value in production!
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ============================================================================
# DEPLOYMENT & CORS CONFIGURATION
# ============================================================================

# CORS_ORIGIN: Allowed origins for cross-origin requests (comma-separated)
# Example for single domain: https://lkimports.com
# Example for multiple: https://lkimports.com,https://www.lkimports.com,https://admin.lkimports.com
# Leave empty in development to use localhost defaults
CORS_ORIGIN=""

# TRUST_PROXY: Set to 'true' if behind a reverse proxy (Cloudflare, nginx, HAProxy, etc)
# Required for correct IP address detection in rate limiting
# Set to 'true' when deployed behind: Cloudflare, Vercel, AWS ALB, nginx, etc
TRUST_PROXY="false"

# PORT: Server port (usually handled by platform in production)
PORT="3006"

# ============================================================================
# GOOGLE REVIEWS (OPTIONAL)
# ============================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls
# Get from: https://ai.google.dev/
GEMINI_API_KEY=""

# VITE_GOOGLE_PLACES_API_KEY: Required to fetch real Google Reviews dynamically
# Get from: Google Cloud Console → Places API
VITE_GOOGLE_PLACES_API_KEY=""

# VITE_GOOGLE_PLACES_PLACE_ID: The Place ID of your business location
# Example: ChIJP1hJOMm_W5MR9pafUPQ5Nts
# Find at: https://mapsplatform.google.com/
VITE_GOOGLE_PLACES_PLACE_ID=""

# ============================================================================
# RATE LIMITING CONFIGURATION (OPTIONAL)
# ============================================================================

# Configure rate limiting thresholds (adjust for your traffic)
# Default: 500 requests per 15 minutes per IP
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX_GLOBAL=500
# RATE_LIMIT_MAX_AUTH=5

