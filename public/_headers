# Cloudflare Pages Headers for Image Optimization
# This file configures caching and security headers for static assets

# Image optimization and caching
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/*.png
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/*.avif
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

# Regular images (not hashed)
/images/*
  Cache-Control: public, max-age=604800
  CDN-Cache-Control: max-age=604800

# Static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

# Security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Enable Cloudflare Image Optimization for all images
/*
  Image-Optimization: true